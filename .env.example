# ════════════════════════════════════════════════════════════════════
# RandomChat Backend — Environment Variables
# Copy this file to .env and fill in real values before running.
# NEVER commit .env to version control.
# ════════════════════════════════════════════════════════════════════

# ── REQUIRED in production (server refuses to start without these) ──

MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/randomchat

# Min 32 chars, cryptographically random
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_HEX

# Exactly 32 characters
ENCRYPTION_KEY=REPLACE_WITH_32_CHARS_EXACTLY__

# X-App-Key sent by Flutter app
APP_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET

# ── CORS ─────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://app.randomchat.app,https://randomchat.app

# ── Server ───────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── Data retention (days) ────────────────────────────────────────────
DATA_RETENTION_DAYS=90

# ── Default admin (change immediately after first login) ─────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ── Grievance Officer (IT Rules 2021, Rule 3(1)(c)) ──────────────────
GRIEVANCE_OFFICER_NAME=Full Name
GRIEVANCE_OFFICER_EMAIL=grievance@randomchat.app
GRIEVANCE_OFFICER_PHONE=+91-XXXXXXXXXX
GRIEVANCE_OFFICER_ADDRESS=Company Name, City, State, India - PINCODE
