# =============================================
# RENAME THIS FILE TO: .env
# =============================================

# MongoDB - Replace with your actual connection string
MONGODB_URI=mongodb+srv://YOUR_DB_USER:YOUR_DB_PASSWORD@your-cluster.mongodb.net/randomchat_db

# JWT Secret
JWT_SECRET=randomchat_jwt_secret_key_2024_very_long_string

# AES Encryption Key for IP addresses (must be exactly 32 characters)
ENCRYPTION_KEY=randomchat2024encryptionkey12345

# Server
PORT=3000
NODE_ENV=development

# Admin Credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@123

# Data Retention (days) - 90 days as per IT Act
DATA_RETENTION_DAYS=90

# App Secret - ALL app/web requests to /api/sessions/* must include:
# Header: X-App-Key: <this value>
APP_SECRET=your_app_secret_here_make_it_long_and_random
